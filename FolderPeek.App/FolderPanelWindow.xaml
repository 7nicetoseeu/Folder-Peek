<Window x:Class="FolderPeek.App.FolderPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Folder Peek"
        Width="380"
        MinWidth="310"
        MaxWidth="520"
        MinHeight="124"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False"
        Background="Transparent"
        Opacity="0"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="Window_OnKeyDown">
    <Border Margin="16"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="{StaticResource ShadowBlurRadius}"
                              ShadowDepth="0"
                              Color="{DynamicResource AppShadowColor}"
                              Opacity="{StaticResource ShadowOpacity}" />
        </Border.Effect>

        <Border x:Name="ChromeBorder"
                Style="{StaticResource PanelChromeStyle}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ChromeTransform" />
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="TitleBarBorder"
                        Padding="16,14,16,12"
                        BorderBrush="{DynamicResource PanelDividerBrush}"
                        BorderThickness="0,0,0,1"
                        Background="{DynamicResource PanelHeaderBrush}"
                        CornerRadius="14,14,0,0"
                        MouseLeftButtonDown="TitleBarBorder_OnMouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="4"
                                Background="{DynamicResource FolderAccentBrush}"
                                CornerRadius="999" />

                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="FolderNameText"
                                       Style="{StaticResource BodyTextStyle}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="文件夹名称" />
                            <TextBlock x:Name="FolderPathText"
                                       Margin="0,5,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap"
                                       Text="路径" />
                            <TextBlock x:Name="ItemCountText"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="0 个项目" />
                        </StackPanel>

                        <Button x:Name="PinToggleButton"
                                Grid.Column="3"
                                Margin="12,0,0,0"
                                VerticalAlignment="Top"
                                Visibility="Collapsed"
                                Style="{StaticResource PanelPinToggleStyle}"
                                ToolTip="钉住当前展开栏"
                                Click="PinToggleButton_OnClick">
                            <TextBlock x:Name="PinGlyphText"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Text="&#xE718;"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Button>
                    </Grid>
                </Border>

                <Border x:Name="NoticeBanner"
                        Grid.Row="1"
                        Margin="12,12,12,0"
                        Visibility="Collapsed"
                        Style="{StaticResource PanelNoticeBannerStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="NoticeTitleText"
                                       Style="{StaticResource CaptionTextStyle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PanelNoticeTitleBrush}"
                                       Text="提示" />
                            <TextBlock x:Name="NoticeDetailText"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Foreground="{DynamicResource PanelNoticeTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="这里会显示轻提示。" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                MinWidth="60"
                                Margin="12,0,0,0"
                                Click="NoticeCloseButton_OnClick"
                                Style="{StaticResource QuietButtonStyle}"
                                Content="关闭" />
                    </Grid>
                </Border>

                <Grid Grid.Row="2"
                      Margin="0,10,0,0">
                    <ListView x:Name="ItemList"
                              Margin="8,0,8,8"
                              Visibility="Collapsed"
                              Style="{StaticResource PanelListViewStyle}"
                              PreviewMouseLeftButtonDown="ItemList_OnPreviewMouseLeftButtonDown"
                              PreviewMouseMove="ItemList_OnPreviewMouseMove"
                              PreviewMouseLeftButtonUp="ItemList_OnPreviewMouseLeftButtonUp">
                        <ListView.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource PanelScrollBarStyle}" />
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource PanelListViewItemStyle}" />
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ItemBackground"
                                        Margin="4,2"
                                        Padding="12,3,12,5"
                                        CornerRadius="8"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="5" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Image Width="16"
                                               Height="16"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Source="{Binding Icon}" />

                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding DisplayName}" />

                                        <TextBlock Grid.Column="2"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PanelSecondaryBrush}"
                                                   FontSize="11"
                                                   Text="{Binding SecondaryText}" />

                                        <TextBlock x:Name="PreviewIndicatorText"
                                                   Grid.Column="3"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PanelPreviewTextBrush}"
                                                   Text="{Binding PreviewIndicator}"
                                                   Visibility="Collapsed" />

                                        <Border x:Name="PreviewProgressBar"
                                                Grid.Row="1"
                                                Grid.ColumnSpan="4"
                                                Height="2"
                                                Margin="8,1,8,0"
                                                VerticalAlignment="Bottom"
                                                Background="{DynamicResource PanelPreviewBrush}"
                                                CornerRadius="999"
                                                Opacity="0"
                                                RenderTransformOrigin="0,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform ScaleX="{Binding DragProgress}" />
                                            </Border.RenderTransform>
                                        </Border>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True">
                                        <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource PanelHoverBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                        <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource PanelSelectedBrush}" />
                                        <Setter TargetName="ItemBackground" Property="BorderBrush" Value="{DynamicResource AccentBorderHoverBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                        <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource PanelExpandedBrush}" />
                                        <Setter TargetName="ItemBackground" Property="BorderBrush" Value="{DynamicResource PanelExpandedBorderBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDragPreviewActive}" Value="True">
                                        <Setter TargetName="ItemBackground" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                        <Setter TargetName="ItemBackground" Property="BorderBrush" Value="{DynamicResource PanelExpandedBorderBrush}" />
                                        <Setter TargetName="PreviewIndicatorText" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="PreviewProgressBar" Property="Opacity" Value="0.95" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border x:Name="StatusPanel"
                            Margin="12,2,12,12"
                            Style="{StaticResource StatusSurfaceStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <ProgressBar x:Name="LoadingBar"
                                         Height="4"
                                         Margin="0,0,0,14"
                                         IsIndeterminate="True" />
                            <TextBlock x:Name="StatusTitleText"
                                       Style="{StaticResource BodyTextStyle}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="正在读取文件夹内容..." />
                            <TextBlock x:Name="StatusDetailText"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Foreground="{DynamicResource PanelMutedBrush}"
                                       TextWrapping="Wrap"
                                       Text="请稍候，Folder Peek 正在准备这一层内容。" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
