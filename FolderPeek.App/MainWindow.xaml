<Window x:Class="FolderPeek.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Folder Peek"
        Width="1040"
        Height="720"
        MinWidth="920"
        MinHeight="620"
        FontFamily="{StaticResource AppFontFamily}"
        Background="{DynamicResource PageBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <TabControl Margin="18"
                TabStripPlacement="Left"
                Background="Transparent"
                BorderThickness="0">
        <TabControl.Resources>
            <Style TargetType="TabItem" BasedOn="{StaticResource SettingsNavTabItemStyle}" />
            <Style TargetType="ScrollBar" BasedOn="{StaticResource PanelScrollBarStyle}" />
        </TabControl.Resources>

        <TabItem Header="主页">
            <ScrollViewer Padding="28,0,28,28"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="820">
                    <TextBlock Style="{StaticResource SettingsPageHeaderStyle}"
                               Text="Folder Peek" />
                    <Border x:Name="HomeStatusBadgeBorder"
                            Margin="0,18,0,0"
                            Style="{StaticResource StatusBadgeStyle}">
                        <TextBlock x:Name="HomeStatusBadgeText"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   FontWeight="SemiBold"
                                   Text="运行中" />
                    </Border>
                    <TextBlock x:Name="HomeStatusTitleText"
                               Margin="0,16,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="Folder Peek 正在后台运行" />
                    <TextBlock x:Name="HomeStatusDetailText"
                               Margin="0,6,0,24"
                               Style="{StaticResource SecondaryBodyTextStyle}"
                               TextWrapping="Wrap"
                               Text="按住 Space，再按住鼠标左键拖动，就可以从桌面文件夹展开内容。" />

                    <TextBlock Style="{StaticResource SettingsGroupTitleStyle}"
                               Text="快速操作" />
                    <Border Margin="0,8,0,22"
                            Padding="6"
                            Style="{StaticResource SettingsGroupStyle}">
                        <UniformGrid Columns="3">
                            <Button Margin="0,0,6,0"
                                    Style="{StaticResource SettingsTileCommandButtonStyle}"
                                    Click="ToggleListeningButton_OnClick">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="ToggleListeningButtonLabel"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="暂停监听" />
                                    <TextBlock Grid.Row="1"
                                               Margin="0,5,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               TextWrapping="Wrap"
                                               Text="停止或恢复手势响应" />
                                </Grid>
                            </Button>

                            <Button Margin="0,0,6,0"
                                    Style="{StaticResource SettingsTileCommandButtonStyle}"
                                    Click="ClosePanelsButton_OnClick">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="关闭全部面板" />
                                    <TextBlock Grid.Row="1"
                                               Margin="0,5,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               TextWrapping="Wrap"
                                               Text="收起当前展开层级" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource SettingsTileCommandButtonStyle}"
                                    Click="ShowDesktopInfoButton_OnClick">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="刷新桌面路径" />
                                    <TextBlock Grid.Row="1"
                                               Margin="0,5,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               TextWrapping="Wrap"
                                               Text="重新读取桌面目录" />
                                </Grid>
                            </Button>
                        </UniformGrid>
                    </Border>

                    <TextBlock Style="{StaticResource SettingsGroupTitleStyle}"
                               Text="行为设置" />
                    <Border Margin="0,8,0,22"
                            Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="开机自启" />
                                        <TextBlock x:Name="StartupSummaryText"
                                                   Margin="0,3,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="登录 Windows 后不会自动启动。" />
                                    </StackPanel>
                                    <ToggleButton x:Name="StartupToggle"
                                                  Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  Checked="StartupToggle_OnCheckedChanged"
                                                  Unchecked="StartupToggle_OnCheckedChanged"
                                                  Style="{StaticResource SwitchToggleStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="显示托盘提示" />
                                        <TextBlock x:Name="TrayTipsSummaryText"
                                                   Margin="0,3,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="启动、暂停和恢复时显示托盘气泡。" />
                                    </StackPanel>
                                    <ToggleButton x:Name="TrayTipsToggle"
                                                  Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  Checked="TrayTipsToggle_OnCheckedChanged"
                                                  Unchecked="TrayTipsToggle_OnCheckedChanged"
                                                  Style="{StaticResource SwitchToggleStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsLastRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="260" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="展开框高度" />
                                        <TextBlock x:Name="PanelVisibleItemCountSummaryText"
                                                   Margin="0,3,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="超过 10 个项目后，展开框内部滚动。" />
                                    </StackPanel>
                                    <Grid Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Margin="18,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="PanelVisibleItemCountSlider"
                                                Minimum="4"
                                                Maximum="20"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                SmallChange="1"
                                                LargeChange="2"
                                                ValueChanged="PanelVisibleItemCountSlider_OnValueChanged" />
                                        <TextBlock x:Name="PanelVisibleItemCountValueText"
                                                   Grid.Column="1"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="10 个" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SettingsGroupTitleStyle}"
                               Text="最近状态" />
                    <Border Margin="0,8,0,0"
                            Style="{StaticResource SettingsGroupStyle}">
                        <ScrollViewer MaxHeight="180"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RecentActivityItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource SettingsRowStyle}">
                                            <TextBlock Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="使用说明">
            <ScrollViewer Padding="28,0,28,28"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="820">
                    <TextBlock Style="{StaticResource SettingsPageHeaderStyle}"
                               Text="使用说明" />

                    <TextBlock Margin="0,24,0,0"
                               Style="{StaticResource SettingsGroupTitleStyle}"
                               Text="操作方式" />
                    <Border Margin="0,8,0,22"
                            Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="1. 按住 Space" />
                                    <TextBlock Margin="0,3,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="保持不放，作为展开手势的起点。" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsRowStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="2. 按住鼠标左键并拖动" />
                                    <TextBlock Margin="0,3,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="在桌面文件夹上拖动，超过阈值后展开第一层。" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsLastRowStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="3. 继续对子文件夹拖动" />
                                    <TextBlock Margin="0,3,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="在展开面板里的子文件夹上重复动作，就能继续级联展开下一层。" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SettingsGroupTitleStyle}"
                               Text="功能特色" />
                    <Border Margin="0,8,0,0"
                            Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="桌面文件夹快速预览" />
                                    <TextBlock Margin="0,3,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="不打开资源管理器，也能从桌面文件夹直接拉出内容面板。" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsRowStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="多层级联展开" />
                                    <TextBlock Margin="0,3,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="面板内的子文件夹支持继续拖动展开，适合顺着目录快速钻取。" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsRowStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="方向感知布局" />
                                    <TextBlock Margin="0,3,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="向左、向右、向上或向下拖动时，面板会尽量沿拖动方向展开。" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsLastRowStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="托盘常驻与主题适配" />
                                    <TextBlock Margin="0,3,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="关闭主窗口后仍可在托盘运行，并支持浅色、深色和跟随系统。" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="外观">
            <ScrollViewer Padding="28,0,28,28"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="760">
                    <TextBlock Style="{StaticResource SettingsPageHeaderStyle}"
                               Text="外观" />

                    <TextBlock Margin="0,24,0,0"
                               Style="{StaticResource SettingsGroupTitleStyle}"
                               Text="主题" />
                    <Border Margin="0,8,0,22"
                            Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsLastRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="320" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="原主题模式" />
                                        <TextBlock x:Name="ThemeModeSummaryText"
                                                   Margin="0,3,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="当前模式：跟随系统（当前浅色）" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource SegmentedControlChromeStyle}">
                                        <UniformGrid Columns="3">
                                            <RadioButton x:Name="ThemeFollowSystemButton"
                                                         GroupName="ThemeMode"
                                                         Checked="ThemeModeButton_OnChecked"
                                                         Style="{StaticResource SegmentedRadioButtonStyle}"
                                                         Content="跟随系统" />
                                            <RadioButton x:Name="ThemeLightButton"
                                                         GroupName="ThemeMode"
                                                         Checked="ThemeModeButton_OnChecked"
                                                         Style="{StaticResource SegmentedRadioButtonStyle}"
                                                         Content="浅色" />
                                            <RadioButton x:Name="ThemeDarkButton"
                                                         GroupName="ThemeMode"
                                                         Checked="ThemeModeButton_OnChecked"
                                                         Style="{StaticResource SegmentedRadioButtonStyle}"
                                                         Content="深色" />
                                        </UniformGrid>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="开发">
            <ScrollViewer Padding="28,0,28,28"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="860">
                    <TextBlock Style="{StaticResource SettingsPageHeaderStyle}"
                               Text="开发" />

                    <TextBlock Margin="0,24,0,0"
                               Style="{StaticResource SettingsGroupTitleStyle}"
                               Text="状态" />
                    <Border Margin="0,8,0,22"
                            Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="当前状态" />
                                    <TextBlock x:Name="HookStateText"
                                               Margin="0,6,0,0"
                                               Text="监听状态：未启动" />
                                    <TextBlock x:Name="TrackingStateText"
                                               Margin="0,4,0,0"
                                               Text="手势状态：空闲" />
                                    <TextBlock x:Name="DirectionText"
                                               Margin="0,4,0,0"
                                               Text="方向：-" />
                                    <TextBlock x:Name="DistanceText"
                                               Margin="0,4,0,0"
                                               Text="拖动距离：0 px" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsLastRowStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="手势起点" />
                                    <TextBlock x:Name="FolderNameText"
                                               Margin="0,6,0,0"
                                               Text="名称：-" />
                                    <TextBlock x:Name="FolderPathText"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               Text="路径：-" />
                                    <TextBlock x:Name="FolderSourceText"
                                               Margin="0,4,0,0"
                                               Text="来源：-" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SettingsGroupTitleStyle}"
                               Text="开发操作" />
                    <Border Margin="0,8,0,22"
                            Style="{StaticResource SettingsGroupStyle}">
                        <StackPanel>
                            <Button Style="{StaticResource SettingsCommandButtonStyle}"
                                    Click="ClearLogButton_OnClick"
                                    Content="清空日志" />
                            <Button Style="{StaticResource SettingsCommandButtonStyle}"
                                    Click="ShowDesktopInfoButton_OnClick"
                                    Content="刷新桌面路径" />
                            <Button Style="{StaticResource SettingsLastCommandButtonStyle}"
                                    Click="ToggleListeningButton_OnClick"
                                    Content="暂停/恢复" />
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SettingsGroupTitleStyle}"
                               Text="事件日志" />
                    <Border Margin="0,8,0,0"
                            Padding="12"
                            Style="{StaticResource SettingsGroupStyle}">
                        <ListBox x:Name="LogList"
                                 MinHeight="280"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemsSource="{Binding LogItems}" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>
