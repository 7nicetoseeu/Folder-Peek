<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="AppShadowColor">#24374C</Color>
    <FontFamily x:Key="AppFontFamily">Microsoft YaHei UI, Microsoft YaHei, Segoe UI Variable Text, Segoe UI</FontFamily>

    <CornerRadius x:Key="WindowCornerRadius">18</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="SectionCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="SmallCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="PillCornerRadius">999</CornerRadius>

    <Thickness x:Key="WindowPadding">0</Thickness>
    <Thickness x:Key="CardPadding">0</Thickness>
    <Thickness x:Key="SectionPadding">0</Thickness>
    <Thickness x:Key="InsetPadding">12</Thickness>
    <Thickness x:Key="ChipPadding">10,6</Thickness>

    <sys:Double x:Key="HeroTitleFontSize">28</sys:Double>
    <sys:Double x:Key="SectionTitleFontSize">20</sys:Double>
    <sys:Double x:Key="BodyFontSize">13.5</sys:Double>
    <sys:Double x:Key="CaptionFontSize">12</sys:Double>
    <sys:Double x:Key="ControlHeight">36</sys:Double>
    <sys:Double x:Key="ShadowOpacity">0.14</sys:Double>
    <sys:Double x:Key="ShadowBlurRadius">28</sys:Double>

    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F3F5F8" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SoftSurfaceBrush" Color="#F8FAFD" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F2F5FA" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#FBFCFE" />
    <SolidColorBrush x:Key="WindowHeaderBrush" Color="#F7F9FC" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#D7DEE8" />
    <SolidColorBrush x:Key="BorderBrushStrong" Color="#CCD5E1" />
    <SolidColorBrush x:Key="DividerBrush" Color="#E8EDF4" />
    <SolidColorBrush x:Key="ItemBorderBrush" Color="#E3E8F0" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#202734" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5D6776" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#6B7685" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#E9F1FF" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#F3F7FF" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#E5EEFF" />
    <SolidColorBrush x:Key="AccentBorderHoverBrush" Color="#BFD4FF" />
    <SolidColorBrush x:Key="TabHoverBrush" Color="#EEF3FA" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#0E8F57" />
    <SolidColorBrush x:Key="StatusRunningBackgroundBrush" Color="#EAF7F0" />
    <SolidColorBrush x:Key="WarningBrush" Color="#B66B0D" />
    <SolidColorBrush x:Key="StatusPausedBackgroundBrush" Color="#FFF4E7" />
    <SolidColorBrush x:Key="HeaderBadgeBrush" Color="#ECF3FF" />
    <SolidColorBrush x:Key="HeaderBadgeTextBrush" Color="#335B94" />
    <SolidColorBrush x:Key="SegmentBackgroundBrush" Color="#EEF2F7" />
    <SolidColorBrush x:Key="SegmentSelectedBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SegmentSelectedBorderBrush" Color="#C4D6F9" />
    <SolidColorBrush x:Key="SegmentSelectedTextBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="FolderAccentBrush" Color="#FFD768" />

    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FCFDFF" />
    <SolidColorBrush x:Key="PanelHeaderBrush" Color="#FFF5E6" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7DEE9" />
    <SolidColorBrush x:Key="PanelDividerBrush" Color="#E7ECF3" />
    <SolidColorBrush x:Key="PanelMutedBrush" Color="#677385" />
    <SolidColorBrush x:Key="PanelSecondaryBrush" Color="#8390A0" />
    <SolidColorBrush x:Key="PanelHoverBrush" Color="#F2F6FD" />
    <SolidColorBrush x:Key="PanelSelectedBrush" Color="#ECF3FF" />
    <SolidColorBrush x:Key="PanelExpandedBrush" Color="#DDEAFF" />
    <SolidColorBrush x:Key="PanelExpandedBorderBrush" Color="#BDD2FB" />
    <SolidColorBrush x:Key="PanelPreviewBrush" Color="#9EC1FF" />
    <SolidColorBrush x:Key="PanelPreviewTextBrush" Color="#42618F" />
    <SolidColorBrush x:Key="PanelNoticeBackgroundBrush" Color="#FFF7E8" />
    <SolidColorBrush x:Key="PanelNoticeBorderBrush" Color="#F0D49F" />
    <SolidColorBrush x:Key="PanelNoticeTitleBrush" Color="#895A05" />
    <SolidColorBrush x:Key="PanelNoticeTextBrush" Color="#745F31" />
    <SolidColorBrush x:Key="PanelScrollTrackBrush" Color="#EEF2F7" />
    <SolidColorBrush x:Key="PanelScrollThumbBrush" Color="#C5CFDC" />
    <SolidColorBrush x:Key="PanelScrollThumbHoverBrush" Color="#AEBBCC" />
    <SolidColorBrush x:Key="PanelScrollButtonHoverBrush" Color="#E7EDF6" />
    <SolidColorBrush x:Key="PanelScrollGlyphBrush" Color="#7B8899" />

    <Style x:Key="HeroTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource HeroTitleFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource SectionTitleFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource BodyFontSize}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SecondaryBodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource BodyFontSize}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource CaptionFontSize}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <Style x:Key="SurfaceCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="WindowHeroCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
        <Setter Property="Background" Value="{DynamicResource WindowHeaderBrush}" />
        <Setter Property="Padding" Value="22" />
    </Style>

    <Style x:Key="SectionCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
        <Setter Property="CornerRadius" Value="{StaticResource SectionCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource SectionPadding}" />
    </Style>

    <Style x:Key="InsetSurfaceStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource InsetPadding}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="InfoChipStyle" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource ChipPadding}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="SegmentedControlChromeStyle" TargetType="Border">
        <Setter Property="Padding" Value="4" />
        <Setter Property="Background" Value="{DynamicResource SegmentBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="StatusBadgeStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="CornerRadius" Value="{StaticResource PillCornerRadius}" />
        <Setter Property="Background" Value="{DynamicResource StatusRunningBackgroundBrush}" />
    </Style>

    <Style x:Key="SettingsPageHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SettingsGroupTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SettingsGroupStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="SettingsRowStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="SettingsLastRowStyle" TargetType="Border" BasedOn="{StaticResource SettingsRowStyle}">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="SettingsCommandButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentPressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsLastCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsCommandButtonStyle}">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="SettingsTileCommandButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="82" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentPressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SettingsNavTabItemStyle" TargetType="TabItem">
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Padding" Value="10,10" />
        <Setter Property="Width" Value="104" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder"
                            Height="40"
                            Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="92" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource SectionCornerRadius}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.56" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="{StaticResource ControlHeight}" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ControlCornerRadius}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentPressedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="QuietButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
    </Style>

    <Style x:Key="PanelPinToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource PanelMutedBrush}" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="ButtonBorder"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ControlCornerRadius}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource SegmentSelectedTextBrush}" />
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource PanelSelectedBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DialogActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="MinWidth" Value="92" />
    </Style>

    <Style x:Key="PageTabItemStyle" TargetType="TabItem">
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{DynamicResource SoftSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource ControlCornerRadius}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SegmentedRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="{StaticResource BodyFontSize}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="SegmentBorder"
                            Margin="2"
                            Padding="12,8"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="{StaticResource SmallCornerRadius}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SegmentBorder" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource SegmentSelectedTextBrush}" />
                            <Setter TargetName="SegmentBorder" Property="Background" Value="{DynamicResource SegmentSelectedBrush}" />
                            <Setter TargetName="SegmentBorder" Property="BorderBrush" Value="{DynamicResource SegmentSelectedBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="SegmentBorder" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SwitchToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="52" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Track"
                            Width="52"
                            Height="30"
                            CornerRadius="15"
                            Background="{StaticResource BorderBrushSoft}"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="1">
                        <Ellipse x:Name="Thumb"
                                 Width="22"
                                 Height="22"
                                 Margin="3"
                                 HorizontalAlignment="Left"
                                 Fill="White" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.94" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Track" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PanelChromeStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource SectionCornerRadius}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="PanelNoticeBannerStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
        <Setter Property="Background" Value="{DynamicResource PanelNoticeBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PanelNoticeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style x:Key="StatusSurfaceStyle" TargetType="Border" BasedOn="{StaticResource InsetSurfaceStyle}">
        <Setter Property="CornerRadius" Value="{StaticResource SectionCornerRadius}" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="PanelListViewStyle" TargetType="ListView">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="SelectionMode" Value="Single" />
    </Style>

    <Style x:Key="PanelScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Width="6"
                            Margin="0"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource PanelScrollThumbBrush}"
                            CornerRadius="999" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource PanelScrollThumbHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource PanelScrollThumbHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PanelScrollBarArrowButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="7">
                        <Viewbox Width="7"
                                 Height="7"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path x:Name="GlyphPath"
                                  Data="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}"
                                  Fill="{DynamicResource PanelScrollGlyphBrush}"
                                  Stretch="Uniform" />
                        </Viewbox>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource PanelScrollButtonHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="GlyphPath" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PanelScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Margin="0,0,2,0"
                          SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="18" />
                        </Grid.RowDefinitions>

                        <RepeatButton Grid.Row="0"
                                      Command="ScrollBar.LineUpCommand"
                                      Style="{StaticResource PanelScrollBarArrowButtonStyle}"
                                      Tag="M 4 6 L 8 2 L 12 6 Z" />

                        <Border Grid.Row="1"
                                Margin="4,2"
                                Background="{DynamicResource PanelScrollTrackBrush}"
                                CornerRadius="999">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False"
                                                  IsTabStop="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource PanelScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False"
                                                  IsTabStop="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>

                        <RepeatButton Grid.Row="2"
                                      Command="ScrollBar.LineDownCommand"
                                      Style="{StaticResource PanelScrollBarArrowButtonStyle}"
                                      Tag="M 4 2 L 8 6 L 12 2 Z" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PanelListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Height" Value="46" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="ActivityItemStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ItemBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
    </Style>
</ResourceDictionary>
